{
  "_comment": "OpenClaw configuration for JARVIS. Run: openclaw start --config openclaw.json",

  "gateway": {
    "port": 18789,
    "secret": "${OPENCLAW_API_KEY}",
    "host":   "0.0.0.0"
  },

  "agents": {
    "defaults": {
      "model": "claude-sonnet-4-6",
      "skills": [
        "gmail-triage",
        "morning-briefing",
        "stock-alerts",
        "calendar-manage",
        "browser-research",
        "obsidian-sync",
        "mcporter"
      ],
      "skill_paths": [
        "./skills"
      ]
    },
    "list": [
      {
        "id":       "jarvis",
        "endpoint": "http://localhost:8000/openclaw/agent/execute",
        "_comment": "JARVIS FastAPI handles execution — OpenClaw is the channel router only"
      }
    ]
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "token":   "${TELEGRAM_BOT_TOKEN}",
      "_comment": "Replaces pyTelegramBotAPI polling in telegram_bot.py"
    },
    "whatsapp": {
      "enabled": false,
      "_comment": "Set to true and run 'openclaw channels whatsapp login' to activate"
    },
    "discord": {
      "enabled": false,
      "token":   "${DISCORD_BOT_TOKEN}",
      "_comment": "Create a bot at discord.com/developers and paste the token"
    },
    "signal": {
      "enabled": false,
      "phone":   "${SIGNAL_PHONE_NUMBER}",
      "_comment": "Requires signal-cli. Less mature than Telegram/WhatsApp."
    },
    "slack": {
      "enabled": false,
      "token":   "${SLACK_BOT_TOKEN}",
      "_comment": "OAuth token from api.slack.com/apps"
    }
  },

  "sessions": {
    "_comment": "Sessions listed here get full operator access. All others are sandboxed.",
    "admin": "${OPENCLAW_ADMIN_SESSIONS}"
  },

  "memory": {
    "backend": "sqlite",
    "path":    "${JARVIS_MEMORY_PATH}"
  },

  "heartbeat": {
    "enabled":          true,
    "interval_minutes": 30,
    "file":             "./HEARTBEAT.md"
  },

  "mcp": {
    "config": "./mcp_servers.json"
  }
}
