# Copy this file to .env and fill in your values.
# For local dev, secrets are read from this file.
# In production (EC2), secrets are pulled from AWS Secrets Manager automatically.

# Environment tag — controls which AWS Secrets Manager path is used (dev/prod)
JARVIS_ENV=dev

ANTHROPIC_API_KEY=your_api_key_here

# ── Map ────────────────────────────────────────────────────────────────────────
# Mapbox public token — get one free at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=pk.your_token_here

# Optional: override the user's name JARVIS uses
JARVIS_USER_NAME=

# Optional: path to JARVIS memory database (default: ~/.jarvis/memory.db)
JARVIS_MEMORY_PATH=

# ── Phase B: Obsidian vault sync ──────────────────────────────────────────────
# Set to your Obsidian vault folder path to mirror all JARVIS memories into
# markdown notes. Leave blank to disable.
# Example (Windows): C:/Users/YourName/Documents/ObsidianVault
# Example (macOS):   /Users/YourName/Documents/ObsidianVault
OBSIDIAN_VAULT_PATH=

# ── Phase B: Scheduler ────────────────────────────────────────────────────────
# Hour (24h) for the morning briefing (default: 8)
BRIEFING_HOUR=8

# Wake word detection confidence threshold (default: 0.5)
WAKEWORD_THRESHOLD=0.5

# Tickers to watch for price alerts, comma-separated (default: AAPL,NVDA,BTC-USD)
ALERT_TICKERS=AAPL,NVDA,BTC-USD

# Percent move that triggers a price alert (default: 2.5)
PRICE_ALERT_PCT=2.5

# Set to 1 to enable hourly email digest nudges
EMAIL_DIGEST_ENABLED=0
EMAIL_DIGEST_INTERVAL_MIN=60

# ── Phase A: Voice ────────────────────────────────────────────────────────────
# Whisper model size: tiny, base, small, medium (default: base)
# Larger = more accurate but slower first load
WHISPER_MODEL=base

# ── Phase C: Telegram ─────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram, then send /start to your bot
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID — JARVIS will reject all other senders.
# Get it by messaging @userinfobot on Telegram.
TELEGRAM_OWNER_ID=

# ── Phase C: Browser automation ───────────────────────────────────────────────
# Set to 0 to show the browser window (useful for debugging)
BROWSER_HEADLESS=1

# ── Phase C: Free dictation ───────────────────────────────────────────────────
# Global hotkey to hold for dictation (pynput format)
# Examples: <ctrl>+<shift>+space   <alt>+d   <ctrl>+<alt>+r
DICTATION_HOTKEY=<ctrl>+<shift>+space
