<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="deploy-flow" name="Deploy Workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" page="1" pageWidth="1654" pageHeight="1169">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Dev flow label -->
        <mxCell id="2" value="DEV FLOW" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#0066CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 1: Write code -->
        <mxCell id="10" value="Write code&#xa;on dev branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 2: Push to dev -->
        <mxCell id="11" value="git push&#xa;origin dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="240" y="90" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 3: docs auto-update -->
        <mxCell id="12" value="Docs workflow&#xa;auto-runs →&#xa;documentation.md updated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- Step 4: Manual deploy dev -->
        <mxCell id="13" value="Actions → Deploy&#xa;select: dev&#xa;▶ Run workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 5: Terraform apply -->
        <mxCell id="14" value="terraform init&#xa;terraform plan&#xa;terraform apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="90" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 6: AWS resources created -->
        <mxCell id="15" value="AWS dev resources&#xa;created in eu-north-1&#xa;EC2 + VPC + Subnet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1010" y="90" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 7: Smoke tests -->
        <mxCell id="16" value="Smoke Tests&#xa;① Plan drift check&#xa;② EC2 running?&#xa;③ HTTP endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1010" y="210" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- Decision: Tests pass? -->
        <mxCell id="17" value="Tests pass?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="820" y="220" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Fix and retry -->
        <mxCell id="18" value="Fix code, push again" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="370" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Production flow label -->
        <mxCell id="19" value="PRODUCTION FLOW" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#006633;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="180" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 8: Merge to main -->
        <mxCell id="20" value="Merge dev → main&#xa;(PR or direct)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 9: Manual deploy production -->
        <mxCell id="21" value="Actions → Deploy&#xa;select: production&#xa;▶ Run workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="260" y="540" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 10: Terraform production -->
        <mxCell id="22" value="terraform init&#xa;terraform plan&#xa;terraform apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="460" y="540" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 11: Production resources -->
