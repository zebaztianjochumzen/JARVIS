# Terraform local state and plugin cache
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# tfvars may contain secrets — envs/ is safe (no credentials, only region/project vars)
*.tfvars
*.tfvars.json
!terraform/envs/*.tfvars

# Plan output files
*tfplan*

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
__pycache__/
*.pyc
.env
models/*.task

# Python virtualenv
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Local secrets
.env
credentials.json
token.json
gmail_token.json
drive_token.json

# Node
frontend/node_modules/
